{
  "manifest_version": 3,
  "name": "Kalshi Sniper",
  "version": "0.1.0",
  "description": "Hover NBA player props on Kalshi and view recent hit rates from Basketball Reference.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://kalshi.com/*",
    "https://*.kalshi.com/*",
    "https://www.basketball-reference.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kalshi.com/*",
        "https://*.kalshi.com/*"
      ],
      "js": [
        "content/kalshiHover.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Kalshi Sniper",
    "default_popup": "ui/popup.html"
  }
}
